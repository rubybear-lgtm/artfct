{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "prepare": "git config core.hooksPath .githooks",
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "types:check": "tsc --noEmit",
        "worker:whoami": "wrangler whoami",
        "worker:kv:create": "cd backend && ../node_modules/.bin/wrangler kv namespace create ARTIFACTS_KV",
        "worker:dev": "cd backend && ../node_modules/.bin/wrangler dev",
        "worker:dev:local": "cd backend && ARTFCT_PUBLIC_BASE_URL=http://127.0.0.1:8788 ../node_modules/.bin/wrangler dev --port 8788",
        "worker:deploy": "node scripts/deploy-worker-version.mjs",
        "worker:deploy:triggers": "cd backend && ../node_modules/.bin/wrangler triggers deploy",
        "waf:rate-limits": "node cloudflare-rate-limits.mjs",
        "waf:rate-limits:env": "node --env-file=.env cloudflare-rate-limits.mjs"
    },
    "devDependencies": {
        "@emnapi/core": "^1.10.0",
        "@emnapi/runtime": "^1.10.0",
        "@eslint/js": "^9.19.0",
        "@laravel/vite-plugin-wayfinder": "^0.1.3",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^22.13.5",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.3",
        "eslint-plugin-react-hooks": "^7.0.0",
        "playwright": "^1.60.0",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "typescript-eslint": "^8.23.0",
        "wrangler": "^4.101.0"
    },
    "dependencies": {
        "@inertiajs/react": "^3.0.0",
        "@inertiajs/vite": "^3.0.0",
        "@tailwindcss/vite": "^4.1.11",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^5.2.0",
        "clsx": "^2.1.1",
        "concurrently": "^10.0.3",
        "globals": "^15.14.0",
        "laravel-vite-plugin": "^3.1",
        "marked": "^18.0.4",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "tailwind-merge": "^3.0.1",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.2",
        "vite": "^8.0.0"
    },
    "overrides": {
        "esbuild": "0.28.1",
        "ws": "8.21.0"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "lightningcss-linux-x64-gnu": "^1.29.1"
    }
}
