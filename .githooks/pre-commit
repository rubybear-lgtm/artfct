#!/usr/bin/env bash
set -euo pipefail

echo "🔍 Scanning staged files for secrets..."

if command -v gitleaks &>/dev/null; then
    if ! gitleaks protect --staged --no-banner --exit-code 1; then
        echo ""
        echo "❌ Potential secrets detected in staged files."
        echo "   Review the findings above before committing."
        echo "   False positive? Override with: git commit --no-verify"
        exit 1
    fi
else
    echo "⚠️  gitleaks not installed — running basic pattern scan."
    echo "   Install for comprehensive detection: brew install gitleaks"
    echo ""

    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

    if [ -z "$STAGED_FILES" ]; then
        echo "✅ No staged files to scan."
        exit 0
    fi

    # Common high-signal secret patterns
    declare -a PATTERNS=(
        'AKIA[0-9A-Z]{16}'                              # AWS access key ID
        'sk-[a-zA-Z0-9]{48}'                            # OpenAI secret key
        'sk-ant-api[0-9]{2}-[a-zA-Z0-9_-]{93,}'        # Anthropic secret key
        'ghp_[a-zA-Z0-9]{36}'                           # GitHub personal access token
        'ghs_[a-zA-Z0-9]{36}'                           # GitHub Actions token
        'xoxb-[0-9]+-[0-9]+-[a-zA-Z0-9]+'              # Slack bot token
        '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY'    # Private key block
        'eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+' # JWT
        '[0-9a-f]{40}'                                  # 40-char hex (API token shape)
    )

    FOUND=0
    for FILE in $STAGED_FILES; do
        for PATTERN in "${PATTERNS[@]}"; do
            if git diff --cached -- "$FILE" | grep -qP "^\+.*${PATTERN}" 2>/dev/null; then
                echo "❌ Potential secret in: $FILE  (pattern: ${PATTERN:0:30}...)"
                FOUND=1
            fi
        done
    done

    if [ "$FOUND" -eq 1 ]; then
        echo ""
        echo "Commit blocked. Review the above."
        echo "False positive? Override with: git commit --no-verify"
        exit 1
    fi
fi

echo "✅ No secrets detected."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

if echo "$STAGED_FILES" | grep -Eq '^(Cargo\.toml|Cargo\.lock|backend/|mcp-server/).*'; then
    export PATH="/opt/homebrew/opt/rustup/bin:$HOME/.cargo/bin:$PATH"

    if ! command -v cargo &>/dev/null; then
        echo "❌ Rust files are staged, but cargo is not installed or not on PATH."
        echo "   Install Rust with rustup, then retry the commit."
        exit 1
    fi

    echo "🦀 Running Rust and CLI pre-commit checks..."

    cargo fmt --all -- --check
    cargo check --workspace --locked
    cargo check -p artfct-backend --target wasm32-unknown-unknown --locked
    cargo test -p artfct --locked
    cargo run -p artfct --locked -- doctor >/dev/null

    echo "✅ Rust and CLI checks passed."
fi

exit 0
